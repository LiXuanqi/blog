{
  "name": "blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:content": "node --import tsx bin/content-generator/cli.ts",
    "generate:content:watch": "NODE_ENV=development node --import tsx bin/content-generator/cli.ts --watch",
    "dev": "concurrently -k -n content,next -c yellow,cyan \"pnpm generate:content:watch\" \"next dev --turbopack\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prebuild": "NODE_ENV=production pnpm generate:content",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-slot": "^1.2.3",
    "@types/js-yaml": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.37",
    "lucide-react": "^0.513.0",
    "next": "15.5.9",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@shikijs/rehype": "3.21.0",
    "@storybook/addon-docs": "10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/addon-themes": "^10.3.3",
    "@storybook/nextjs-vite": "^10.3.3",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.16",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.5.3",
    "shiki": "3.21.0",
    "storybook": "^10.3.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,mdx}": [
      "prettier --write"
    ]
  }
}
